{
  "expo": {
    "name": "Nachi",
    "slug": "anvesh911",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#070B14",
    "scheme": "nachi",
    "platforms": ["android"],

    "android": {
      "package": "com.nachi.callmemory",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE"
      ]
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-notifications"
    ]
  }
}

{
  "expo": {
    "name": "AnVy",
    "slug": "anvy",
    "version": "1.0.0",

    "orientation": "portrait",

    "icon": "./assets/icon.png",

    "scheme": "anvy",

    "userInterfaceStyle": "dark",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "bundleIdentifier": "com.anvy.app"
    },

    "android": {
      "package": "com.anvy.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },

    "plugins": [
      "expo-router"
    ],

    "extra": {
      "eas": {
        "projectId": "999d6f8c-96bd-4429-81d4-28ef5b028163"
      }
    }
  }
}
